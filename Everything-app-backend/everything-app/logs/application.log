        ce1_0.related_workout_id,
        ce1_0.start_time,
        ce1_0.title,
        ce1_0.updated_at,
        ce1_0.user_id 
    from
        calendar_events ce1_0 
    where
        ce1_0.user_id=? 
        and ce1_0.start_time between ? and ?
